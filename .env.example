# ============================================
# Paper Writing — 环境变量示例
# 正常情况下 install.sh 会自动生成 .env，不需要手动改
# ============================================

# 激活码（必填，由服务商发放）
LICENSE_CODE=YOUR_CODE_HERE

# 对外访问端口
FRONTEND_PORT=8090
DB_PORT=5433
REDIS_PORT=6381

# 数据库
DB_NAME=paper_writing
DB_USER=postgres
DB_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT / 加密（32 字节 hex，install.sh 会随机生成）
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars_long
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# 登录 / CORS（根据实际服务器 IP/域名修改）
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/
AUTH_COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:8090

# 镜像
BACKEND_IMAGE=ghcr.io/goingu/paper-writing-standalone/backend
FRONTEND_IMAGE=ghcr.io/goingu/paper-writing-standalone/frontend
BACKEND_PYTHON_IMAGE=ghcr.io/goingu/paper-writing-standalone/backend-python
IMAGE_TAG=main

# Python 导出服务（容器网络内访问，不需要改）
PYTHON_EXPORT_URL=http://backend-python:5001
# OCR 凭证（可选,留空则导出走 mock OCR）
SILICONFLOW_API_KEY=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
